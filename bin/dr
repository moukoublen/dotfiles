#!/usr/bin/env bash

# dr is a shortcut to execute `docker run` command with --rm --interactive --tty arguments prefilled.
#   eg: dr golang:1.23
# All arguments are passed to docker run except:
#   -R, --RO    which is translated to read-only `:ro` volume bind of the current directory
#   --ME        which is translated to `--user=$(id -u):$(id -g)`
#
# To enable `docker run` run (or put in ~/.bashrc or ~/.profile e.t.c.):
#
# source <(dr --bash-completion)
#

__dr_bash_completion() {
  # Docker uses cobra's V2 shell completion, exposed via `docker completion bash`.
  # This generates helper functions (e.g. __start_docker, __docker_get_completion_results)
  # that drive completion by calling `docker __complete <subcommand> <args...>` at runtime.
  # We source it lazily — only once per shell session — by checking for __start_docker.
  [[ "$(type -t __start_docker)" != "function" ]] &&
    . <(docker completion bash)

  # Standard bash-completion setup: populates cur (word under cursor), prev (word before
  # it), words (full command line as array), cword (index of cur within words), and split
  # (true when completing after '='). The -n =: flag treats '=' and ':' as non-word-break
  # characters so flag values like --net=host complete correctly.
  local cur prev words cword split
  COMPREPLY=()

  if declare -F _init_completion >/dev/null 2>&1; then
    _init_completion -n =: || return
  else
    # Fallback for systems without the bash-completion package (e.g. macOS with bash 3).
    __docker_init_completion -n =: || return
  fi

  # At this point words[0]="dr" and words[1..] are the arguments the user typed.
  # Docker's completion machinery calls: ${words[0]} __complete ${words[@]:1}
  # so we rewrite words to look like a `docker run` invocation:
  #   before: dr        --rm  ubuntu  bash
  #   after:  docker  run  --rm  ubuntu  bash
  # cword is shifted by 1 to keep it pointing at the same token the cursor is on.
  words=("docker" "run" "${words[@]:1}")
  cword=$(( cword + 1 ))

  # Delegate to docker's V2 completion internals:
  #   __docker_get_completion_results  — calls `docker __complete run <args>` and
  #                                      captures the output + directive integer.
  #   __docker_process_completion_results — interprets the directive (NoSpace, NoFileComp,
  #                                         FilterDirs, …) and populates COMPREPLY.
  local out directive
  __docker_get_completion_results
  __docker_process_completion_results
}

READ_ONLY=""
MOUNT_PWD=""
USR=""
args=()

args+=('--rm')
args+=('--interactive')
args+=('--tty')

while (($#)); do
  case "${1}" in
    -R | --RO)
      READ_ONLY=":ro"
      shift
      ;;
    -H | --HERE)
      MOUNT_PWD="1"
      shift
      ;;
    --ME)
      USR="--user=$(id -u):$(id -g)"
      shift
      ;;
    --ROOT)
      USR='--user=0:0'
      shift
      ;;
    --bash-completion)
      declare -f __dr_bash_completion
      echo ''
      echo 'complete -F __dr_bash_completion dr'
      exit 0
      ;;
    *)
      args+=("${1}")
      shift
      ;;
  esac
done

if [[ ${MOUNT_PWD} == "1" ]]; then
  FOLDER="/v/$(basename "${PWD}")"
  # prepend
  args=("--volume" "${PWD}:${FOLDER}${READ_ONLY}" --workdir "${FOLDER}" "${args[@]}")
fi

if [[ -n ${USR} ]]; then
  # prepend
  args=("${USR}" "${args[@]}")
fi

set -x
exec docker run "${args[@]}"
