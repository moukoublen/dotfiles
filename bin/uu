#!/usr/bin/env bash

__log() {
  echo -e "\e[0;90mв–€в–“в–’в–‘\e[0m \e[0;90m${*}\e[0m"
}

__cmd() {
  __log "${*}"
  "${@}"
}

__header() {
  echo -e "\e[0;35mв•­в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•®\e[0m"
  printf '\e[0;35mв•°\e[0m \e[0;95m%-35s\e[0m \e[0;35mв•Ї\e[0m' "${*}"
  echo ""
}

update-dnf() {
  if [[ $(uname) != "Linux" ]]; then
    return 0
  fi
  if ! command -v dnf &>/dev/null; then
    return 0
  fi
  __header linux with dnf
  __cmd sudo dnf upgrade --refresh
  __cmd dnf needs-restarting --reboothint
  # https://dnf-plugins-core.readthedocs.io/en/latest/needs_restarting.html
}

update-apt() {
  if [[ $(uname) != "Linux" ]]; then
    return 0
  fi
  if ! command -v apt &>/dev/null; then
    return 0
  fi
  __header linux with apt
  __cmd sudo apt update
  __cmd sudo apt upgrade
  [[ -e /var/run/reboot-required ]] && __log "reboot is required"
}

update-snap() {
  if ! command -v snap &>/dev/null; then
    return 0
  fi
  __header snap
  __cmd sudo snap refresh
  __cmd snap-clean-disabled
}

update-flatpak() {
  if ! command -v flatpak &>/dev/null; then
    return 0
  fi
  __header flatpak
  __cmd sudo flatpak update
  __cmd flatpak update
}

update-homebrew() {
  if ! command -v brew &>/dev/null; then
    return 0
  fi
  __header homebrew
  __cmd brew update
  __cmd brew upgrade
  __cmd brew cleanup
}

update-mise() {
  if ! command -v mise &>/dev/null; then
    return 0
  fi
  __header mise
  __cmd mise self-update
  __cmd mise upgrade --bump
}

update-customs() {
  __header customs
  if [[ $(uname) == "Linux" ]]; then
    __cmd "${DOTFILES_PATH}"/scripts/install-docker-buildx
    __cmd "${DOTFILES_PATH}"/scripts/install-docker-compose
  fi
  __cmd "${DOTFILES_PATH}"/scripts/install-elastic-package
}

update-customs
update-dnf
update-apt
update-snap
update-flatpak
update-homebrew
update-mise
